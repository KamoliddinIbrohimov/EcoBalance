// Eco-Balance Platform — Prisma schema (Phase 0)
// PostgreSQL 16 with UUIDv7 default IDs (via app-level uuid v7)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------
// Enums
// ---------------------------------------------------------------

enum RoleSlug {
  SUPER_ADMIN
  ADMIN
  CITY_ADMIN
  MAHALLA_MANAGER
  TEACHER
  STUDENT
  CITIZEN
}

enum OrganizationType {
  CITY
  DISTRICT
  MAHALLA
  SCHOOL
  KINDERGARTEN
  UNIVERSITY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_COMPLETE
  TOKEN_REFRESH
  TOKEN_REVOKED
}

// ---------------------------------------------------------------
// Users, roles, permissions
// ---------------------------------------------------------------

model User {
  id                String    @id @db.Uuid
  firstName         String    @map("first_name")   @db.VarChar(100)
  lastName          String    @map("last_name")    @db.VarChar(100)
  email             String    @unique              @db.VarChar(255)
  phone             String?   @unique              @db.VarChar(32)
  passwordHash      String    @map("password_hash") @db.VarChar(255)
  avatarUrl         String?   @map("avatar_url")   @db.VarChar(512)
  locale            String    @default("uz")       @db.VarChar(8)
  emailVerifiedAt   DateTime? @map("email_verified_at")
  lastLoginAt       DateTime? @map("last_login_at")
  lastLoginIp       String?   @map("last_login_ip") @db.VarChar(45)
  isActive          Boolean   @default(true)       @map("is_active")

  organizationId    String?   @map("organization_id") @db.Uuid
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  roles             UserRole[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  passwordResets    PasswordResetToken[]

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt      @map("updated_at")

  @@index([organizationId])
  @@index([createdAt(sort: Desc)])
  @@map("users")
}

model Role {
  id          String        @id @db.Uuid
  slug        RoleSlug      @unique
  nameUz      String        @map("name_uz") @db.VarChar(120)
  description String?       @db.VarChar(500)

  users       UserRole[]
  permissions RolePermission[]

  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt      @map("updated_at")

  @@map("roles")
}

model Permission {
  id        String            @id @db.Uuid
  slug      String            @unique @db.VarChar(120)   // e.g. "users.create"
  module    String            @db.VarChar(60)             // e.g. "users"
  action    String            @db.VarChar(60)             // e.g. "create"
  nameUz    String            @map("name_uz") @db.VarChar(160)

  roles     RolePermission[]

  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt      @map("updated_at")

  @@index([module])
  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ---------------------------------------------------------------
// Organizations (city → district → mahalla; also schools/universities)
// ---------------------------------------------------------------

model Organization {
  id          String            @id @db.Uuid
  parentId    String?           @map("parent_id") @db.Uuid
  parent      Organization?     @relation("OrgTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Organization[]    @relation("OrgTree")

  type        OrganizationType
  nameUz      String            @map("name_uz") @db.VarChar(255)
  code        String            @unique @db.VarChar(60)  // e.g. "chirchiq", "kimyogar-mahalla"
  address     Json?             @db.JsonB
  latitude    Decimal?          @db.Decimal(10, 7)
  longitude   Decimal?          @db.Decimal(10, 7)

  users       User[]

  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt      @map("updated_at")

  @@index([parentId])
  @@index([type])
  @@map("organizations")
}

// ---------------------------------------------------------------
// Audit log
// ---------------------------------------------------------------

model AuditLog {
  id           String       @id @db.Uuid
  userId       String?      @map("user_id") @db.Uuid
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  action       AuditAction
  subjectType  String?      @map("subject_type") @db.VarChar(120)
  subjectId    String?      @map("subject_id")   @db.Uuid
  changes      Json?        @db.JsonB
  ipAddress    String?      @map("ip_address") @db.VarChar(45)
  userAgent    String?      @map("user_agent") @db.VarChar(500)

  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([subjectType, subjectId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ---------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------

model Notification {
  id        String    @id @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String    @db.VarChar(120)
  titleUz   String    @map("title_uz") @db.VarChar(255)
  bodyUz    String    @map("body_uz")  @db.Text
  data      Json?     @db.JsonB
  readAt    DateTime? @map("read_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")

  @@index([userId, readAt])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// ---------------------------------------------------------------
// Auth tokens
// ---------------------------------------------------------------

model RefreshToken {
  id            String    @id @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash     String    @unique @map("token_hash") @db.VarChar(255)
  familyId      String    @map("family_id") @db.Uuid   // rotation family — reuse detection
  revokedAt     DateTime? @map("revoked_at")
  expiresAt     DateTime  @map("expires_at")

  ipAddress     String?   @map("ip_address") @db.VarChar(45)
  userAgent     String?   @map("user_agent") @db.VarChar(500)

  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

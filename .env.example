# ============================================================
# Eco-Balance Platform — shared environment
# Copy to .env and adjust for your local machine
# ============================================================

# --- Global ---
COMPOSE_PROJECT_NAME=eco-balance
NODE_ENV=development
APP_ENV=local
APP_TIMEZONE=Asia/Tashkent

# --- Nginx / public URLs ---
NGINX_HTTP_PORT=80
APP_URL=http://localhost
API_URL=http://localhost/api/v1

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecobalance
POSTGRES_USER=ecobalance
POSTGRES_PASSWORD=ecobalance_secret_change_me
DATABASE_URL=postgresql://ecobalance:ecobalance_secret_change_me@postgres:5432/ecobalance?schema=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1
REDIS_SESSION_DB=2

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=ecobalance
MINIO_ROOT_PASSWORD=ecobalance_minio_change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=ecobalance
S3_SECRET_KEY=ecobalance_minio_change_me
S3_BUCKET_PUBLIC=ecobalance-public
S3_BUCKET_PRIVATE=ecobalance-private

# --- API (NestJS) ---
API_PORT=4000
API_APP_NAME="Eco-Balance API"
API_LOG_LEVEL=debug

# JWT (min 32 chars each — replace in prod)
JWT_ACCESS_SECRET=change-me-access-256-bit-secret-eco-balance-phase-0
JWT_REFRESH_SECRET=change-me-refresh-256-bit-secret-eco-balance-phase-0
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# Mail (Mailpit in dev)
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@eco-balance.uz"
MAIL_FROM_NAME="Eco-Balance Platformasi"

# Rate limits
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_AUTH=10
RATE_LIMIT_FORGOT_PASSWORD=3

# Sentry (leave empty to disable)
SENTRY_DSN=

# --- Web (Next.js) ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost/api/v1
NEXT_PUBLIC_APP_NAME="Eco-Balance"
NEXT_PUBLIC_DEFAULT_LOCALE=uz
NEXT_PUBLIC_SENTRY_DSN=

# --- Super admin (used by Prisma seed on first migrate) ---
SUPER_ADMIN_EMAIL=admin@eco-balance.uz
SUPER_ADMIN_PASSWORD=ChangeMe!2026
SUPER_ADMIN_FIRST_NAME=Bosh
SUPER_ADMIN_LAST_NAME=Administrator

# ============================================================
# Eco-Balance — PRODUCTION environment
#
# Copy this file to `.env` on the server (NEVER commit the filled .env):
#   scp .env.production.example root@62.171.187.218:~/eco-balance/.env
#   ssh root@62.171.187.218 -- vi ~/eco-balance/.env
#
# Fill in every secret placeholder ("CHANGE_ME_...") with a real value.
# ============================================================

# --- Global ---
COMPOSE_PROJECT_NAME=eco-balance
NODE_ENV=production
APP_ENV=production
APP_TIMEZONE=Asia/Tashkent

# --- Public URL ---
APP_URL=http://62.171.187.218:8890
API_URL=http://62.171.187.218:8890/api/v1

# --- Host port (the ONLY port exposed to the outside) ---
NGINX_HTTP_PORT=8890

# --- Container image tags (set by CI on push to main) ---
# Leave the defaults if the images live under kamoliddinibrohimov/*.
GHCR_IMAGE_API=ghcr.io/kamoliddinibrohimov/ecobalance-api:latest
GHCR_IMAGE_WEB=ghcr.io/kamoliddinibrohimov/ecobalance-web:latest

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecobalance
POSTGRES_USER=ecobalance
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
DATABASE_URL=postgresql://ecobalance:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/ecobalance?schema=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_CACHE_DB=0
REDIS_QUEUE_DB=1
REDIS_SESSION_DB=2

# --- MinIO (internal only — not exposed to host in prod) ---
MINIO_ROOT_USER=ecobalance
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=ecobalance
S3_SECRET_KEY=CHANGE_ME_STRONG_MINIO_PASSWORD
S3_BUCKET_PUBLIC=ecobalance-public
S3_BUCKET_PRIVATE=ecobalance-private

# --- API (NestJS) ---
API_PORT=4000
API_APP_NAME="Eco-Balance API"
API_LOG_LEVEL=info

# JWT — generate a fresh 64-char secret each:
#   openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Cookies ---
COOKIE_DOMAIN=62.171.187.218
COOKIE_SECURE=false

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://62.171.187.218:8890

# --- Mail (replace with a real SMTP relay in prod) ---
MAIL_HOST=smtp.example.uz
MAIL_PORT=587
MAIL_USER=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS="no-reply@eco-balance.uz"
MAIL_FROM_NAME="Eco-Balance Platformasi"

# --- Rate limits (prod values) ---
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_AUTH=10
RATE_LIMIT_FORGOT_PASSWORD=3

# --- Sentry (optional but recommended) ---
SENTRY_DSN=

# --- Web (Next.js) ---
# Relative URL — nginx routes /api/* to the api container on the same origin,
# so no CORS and no rebuild needed if the public IP/domain changes.
WEB_PORT=3000
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_APP_NAME="Eco-Balance"
NEXT_PUBLIC_DEFAULT_LOCALE=uz
NEXT_PUBLIC_SENTRY_DSN=

# --- Super admin (used by Prisma seed on first migrate) ---
SUPER_ADMIN_EMAIL=admin@eco-balance.uz
SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
SUPER_ADMIN_FIRST_NAME=Bosh
SUPER_ADMIN_LAST_NAME=Administrator
